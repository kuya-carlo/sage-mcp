# ============================================================
# SAGE — Student Agent for Guided Education
# .env.example — copy to .env and fill in values
# NEVER commit .env to git — it's in .gitignore already
# ============================================================

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------

# Public URL of your deployed app (Cloudflare Tunnel domain)
# Used by: agent.py (internal MCP tool calls),
#          Notion OAuth redirect URI
APP_BASE_URL=https://sage.yourdomain.com

# Secret key for Fernet symmetric encryption of Notion tokens
# Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Used by: routers/auth.py, services/mcp_tools/workspace.py
FERNET_KEY=

# Secret key for /admin/* endpoint protection
# Generate once with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Used by: routers/admin.py (X-Admin-Key header check)
ADMIN_KEY=

# ------------------------------------------------------------
# SUPABASE
# ------------------------------------------------------------

# Your Supabase project URL
# Found at: Supabase Dashboard → Project Settings → API
# Used by: database.py
SUPABASE_URL=https://yourproject.supabase.co

# Service role key (NOT anon key — service role bypasses RLS)
# Found at: Supabase Dashboard → Project Settings → API
# Used by: database.py
SUPABASE_KEY=

# Direct PostgreSQL connection string
# Found at: Supabase Dashboard → Project Settings → Database
# IMPORTANT: URL-encode special chars in password
#   $ → %24, / → %2F, + → %2B, = → %3D, , → %2C, @ → %40
# Append ?prepared_statement_cache_size=0 to avoid
# PgBouncer prepared statement errors
# Used by: database.py (asyncpg direct connection)
SUPABASE_DB_URL=postgresql://postgres:urlencoded_password@db.yourproject.supabase.co:5432/postgres?prepared_statement_cache_size=0

# ------------------------------------------------------------
# NOTION
# ------------------------------------------------------------

# Internal integration secret (starts with secret_...)
# Created at: notion.so/my-integrations → New integration
# Capabilities needed: Read, Update, Insert content
# Used by: services/mcp_tools/workspace.py (MVP)
#          routers/auth.py (post-hackathon OAuth)
NOTION_INTERNAL_TOKEN=secret_

# Your Notion workspace ID
# Get it by running:
#   curl https://api.notion.com/v1/users/me \
#     -H "Authorization: Bearer secret_yourtoken" \
#     -H "Notion-Version: 2022-06-28"
# Used by: routers/auth.py, services/mcp_tools/*
NOTION_WORKSPACE_ID=

# ID of the root Notion page SAGE will build under
# Create a blank page in Notion called "SAGE Workspace"
# URL looks like: notion.so/yourworkspace/pageid
# The pageid part (with hyphens added) is this value
# Used by: services/mcp_tools/workspace.py
NOTION_ROOT_PAGE_ID=

# OAuth credentials (post-hackathon — leave blank for MVP)
# Created at: notion.so/my-integrations → public integration
# Used by: routers/auth.py (v1.1 OAuth flow)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/auth/callback

# ------------------------------------------------------------
# OPENROUTER
# ------------------------------------------------------------

# OpenRouter API key
# Created at: openrouter.ai → Keys → Create Key
# Used by: services/agent.py, services/etl/extractor.py,
#          services/mcp_tools/tasks.py, sensor.py
OPENROUTER_API_KEY=

# These help OpenRouter track usage and unlock
# some model access tiers
# Used by: all OpenRouter API calls as headers
OR_SITE_URL=https://sage.yourdomain.com
OR_APP_NAME=SAGE

# ------------------------------------------------------------
# GOOGLE CLOUD / DOCUMENT AI
# ------------------------------------------------------------

# GCP project ID
# Found at: console.cloud.google.com → project selector
# Used by: services/etl/documentai.py
GOOGLE_CLOUD_PROJECT=sage-hackathon

# Document AI processor region
# Use "us" unless you created the processor in another region
# Used by: services/etl/documentai.py
GOOGLE_CLOUD_LOCATION=us

# Document AI processor ID
# Found at: GCP Console → Document AI → your processor
# Used by: services/etl/documentai.py
DOCUMENT_AI_PROCESSOR_ID=

# Base64-encoded service account JSON key
# Generate with:
#   base64 -w 0 your-service-account-key.json  (Linux)
#   base64 -i your-service-account-key.json    (Mac)
# Used by: services/etl/documentai.py
# NEVER paste the raw JSON — always base64 encode it
GOOGLE_CREDENTIALS_BASE64=

# ------------------------------------------------------------
# GAFFA
# ------------------------------------------------------------

# Gaffa API key for web scraping and search
# Found at: your Gaffa dashboard → API Keys
# Used by: services/etl/gaffa.py
GAFFA_API_KEY=
